<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="citygraph.ui.Controllers.HomeController"
      spacing="12">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="CityGraph" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <Button text="Gestión de Paradas" onAction="#onParadas" prefWidth="240"/>
    <Button text="Gestión de Rutas" onAction="#onRutas" prefWidth="240"/>
    <Button text="Calcular Ruta (Dijkstra)" onAction="#onCalcular" prefWidth="240"/>

</VBox>