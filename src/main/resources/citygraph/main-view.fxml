<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/25.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="citygraph.ui.Controllers.MainController"
      stylesheets="@styles.css"
      prefWidth="560" prefHeight="480"
      spacing="16"
      style="-fx-background-color: -color-bg;">

    <padding>
        <Insets top="24" right="28" bottom="24" left="28"/>
    </padding>

    <VBox spacing="4">
        <Label text="🗺 CityGraph" styleClass="lbl-title"/>
        <Label text="Sistema de rutas de transporte" styleClass="lbl-section"/>
    </VBox>

    <Separator/>

    <VBox spacing="10" styleClass="card">
        <Label text="Parámetros de búsqueda" styleClass="lbl-section"/>

        <GridPane hgap="12" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="90" prefWidth="90"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="Origen" styleClass="label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbOrigen" prefWidth="300" maxWidth="Infinity"
                      GridPane.rowIndex="0" GridPane.columnIndex="1"
                      GridPane.hgrow="ALWAYS"/>

            <Label text="Destino" styleClass="label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbDestino" prefWidth="300" maxWidth="Infinity"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"
                      GridPane.hgrow="ALWAYS"/>

            <Label text="Criterio" styleClass="label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbCriterio" prefWidth="300" maxWidth="Infinity"
                      GridPane.rowIndex="2" GridPane.columnIndex="1"
                      GridPane.hgrow="ALWAYS"/>
        </GridPane>
    </VBox>

    <HBox spacing="10">
        <Button text="⚡  Calcular Ruta"
                onAction="#onCalcular"
                styleClass="btn-primary"
                prefWidth="150"/>
        <Button text="↺  Cargar Demo"
                onAction="#onCargarDemo"
                prefWidth="140"/>
    </HBox>

    <Separator/>

    <Label text="Resultado" styleClass="lbl-section"/>
    <TextArea fx:id="txtResultado" prefRowCount="8" wrapText="true"
              VBox.vgrow="ALWAYS"
              style="-fx-font-size: 13px; -fx-font-family: 'Courier New', monospace;"/>

</VBox>
