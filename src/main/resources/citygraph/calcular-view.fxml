<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="citygraph.ui.Controllers.CalcularController"
            stylesheets="@styles.css"
            prefWidth="620" prefHeight="520"
            style="-fx-background-color: -color-bg;">

    <!-- Top bar -->
    <top>
        <HBox styleClass="top-bar">
            <Button text="← Volver" onAction="#onVolver" styleClass="btn-back"/>
            <Label text="Calcular Ruta Óptima" styleClass="lbl-page-title"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>

            <!-- Selección de paradas y criterio -->
            <VBox spacing="10" styleClass="card">

                <Label text="Parámetros de búsqueda" styleClass="lbl-section"/>

                <GridPane hgap="12" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="90" prefWidth="90"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Origen" styleClass="label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbOrigen" maxWidth="Infinity"
                              GridPane.rowIndex="0" GridPane.columnIndex="1"
                              GridPane.hgrow="ALWAYS"/>

                    <Label text="Destino" styleClass="label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbDestino" maxWidth="Infinity"
                              GridPane.rowIndex="1" GridPane.columnIndex="1"
                              GridPane.hgrow="ALWAYS"/>

                    <Label text="Criterio" styleClass="label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cmbCriterio" maxWidth="Infinity"
                              GridPane.rowIndex="2" GridPane.columnIndex="1"
                              GridPane.hgrow="ALWAYS"/>
                </GridPane>

            </VBox>

            <!-- Botones -->
            <HBox spacing="10">
                <Button text="⚡  Calcular"
                        onAction="#onCalcular"
                        styleClass="btn-primary"
                        prefWidth="140"/>
                <Button text="↻  Refrescar paradas"
                        onAction="#onRefrescar"
                        prefWidth="160"/>
            </HBox>

            <Separator/>

            <!-- Resultado -->
            <Label text="Resultado" styleClass="lbl-section"/>
            <TextArea fx:id="txtResultado" editable="false" VBox.vgrow="ALWAYS"
                      style="-fx-font-size: 13px; -fx-font-family: 'Courier New', monospace;"/>

            <Pane fx:id="mapPane" prefWidth="700.0" prefHeight="420.0"
                  style="-fx-background-color: white; -fx-border-color: #cccccc;" />

        </VBox>
    </center>

</BorderPane>
