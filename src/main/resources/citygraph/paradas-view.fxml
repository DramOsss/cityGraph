<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="citygraph.ui.Controllers.ParadasController"
            stylesheets="@styles.css"
            prefWidth="780" prefHeight="520"
            style="-fx-background-color: -color-bg;">

    <!-- Top bar -->
    <top>
        <HBox styleClass="top-bar">
            <Button text="← Volver" onAction="#onVolver" styleClass="btn-back"/>
            <Label text="Gestión de Paradas" styleClass="lbl-page-title"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.42" style="-fx-background-color: -color-bg;">

            <!-- Panel izquierdo: lista -->
            <VBox spacing="10" styleClass="panel-left">
                <padding>
                    <Insets top="16" right="14" bottom="16" left="16"/>
                </padding>

                <Label text="Paradas registradas" styleClass="lbl-section"/>
                <ListView fx:id="lstParadas" VBox.vgrow="ALWAYS"/>

                <Button text="🗑  Eliminar seleccionada"
                        onAction="#onEliminarParada"
                        styleClass="btn-danger"
                        prefWidth="220"/>
            </VBox>

            <!-- Panel derecho: formulario -->
            <VBox spacing="14" styleClass="panel-right">
                <padding>
                    <Insets top="16" right="20" bottom="16" left="20"/>
                </padding>

                <Label text="Datos de la parada" styleClass="lbl-section"/>

                <VBox spacing="10" styleClass="card">

                    <GridPane hgap="12" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="90" prefWidth="90"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="ID" styleClass="label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtId" promptText="Ej: A1"
                                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Nombre" styleClass="label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtNombre" promptText="Ej: Centro Histórico"
                                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    </GridPane>

                </VBox>

                <HBox spacing="8">
                    <Button text="✚  Agregar"
                            onAction="#onAgregarParada"
                            styleClass="btn-primary"
                            prefWidth="120"/>
                    <Button text="✎  Modificar"
                            onAction="#onModificarParada"
                            prefWidth="120"/>
                    <Button text="✕  Limpiar"
                            onAction="#onNuevaParada"
                            prefWidth="110"/>
                </HBox>

                <Separator/>

                <Label text="Estado" styleClass="lbl-section"/>
                <TextArea fx:id="txtMsg" editable="false" prefRowCount="4"
                          style="-fx-font-size: 12px;"/>

            </VBox>

        </SplitPane>
    </center>

</BorderPane>
